OPENAI_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
CORS_ORIGINS=http://localhost:5173

# Postgres — used by backend/db.py
# Override DATABASE_URL if using an external host; docker-compose sets it automatically
POSTGRES_PASSWORD=intake
DATABASE_URL=postgresql://intake:intake@localhost:5432/intake

# OpenEMR FHIR endpoint (only needed when running: docker compose --profile testing up)
OPENEMR_FHIR_URL=http://localhost/apis/default/fhir
OPENEMR_CLIENT_ID=
OPENEMR_CLIENT_SECRET=

# LangSmith (optional — remove to disable tracing)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=clinical-brief
LANGCHAIN_TRACING_V2=true
